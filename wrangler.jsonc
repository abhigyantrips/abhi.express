{
	"$schema": "./node_modules/wrangler/config-schema.json",

	"name": "abhi-express",
	"main": "@astrojs/cloudflare/entrypoints/server",

	"compatibility_date": "2026-07-10",
	"compatibility_flags": ["global_fetch_strictly_public"],

	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
	},

	"observability": {
		"enabled": true,
	},

	"workers_dev": false,
	"preview_urls": false,
	"routes": [
		{
			"pattern": "abhi.express",
			"custom_domain": true,
		},
	],
}
